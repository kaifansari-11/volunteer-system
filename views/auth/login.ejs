<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <div class="logo-icon"><i class="fa-solid fa-handshake-angle"></i></div>
      VolunteerHub
    </div>
    <p class="auth-subtitle">Sign in to your account to continue</p>

    <% if (error && error.length) { %>
      <div class="alert alert-error"><i class="fa-solid fa-circle-exclamation"></i> <%= error[0] %></div>
    <% } %>
    <% if (success && success.length) { %>
      <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> <%= success[0] %></div>
    <% } %>

    <form action="/auth/login" method="POST">
      <div class="form-group">
        <label class="form-label">Email Address</label>
        <input type="email" name="email" class="form-control" placeholder="you@example.com" required autofocus>
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" placeholder="Enter your password" required>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; padding:12px;">
        Sign In <i class="fa-solid fa-arrow-right" style="margin-left: 6px;"></i>
      </button>
    </form>

    <div class="auth-divider"><span>New to VolunteerHub?</span></div>
    <a href="/auth/register" class="btn btn-ghost" style="width:100%; justify-content:center;">
      Create an account
    </a>
  </div>
</div>
</body>
</html>