<!DOCTYPE html>
<html lang="en">
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Server Error</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    .error-page { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: var(--slate-50); text-align: center; padding: 20px; }
    .error-code { font-size: 80px; font-weight: 700; color: var(--red); line-height: 1; margin-bottom: 10px; }
    .error-title { font-size: 24px; color: var(--slate-900); margin-bottom: 20px; }
  </style>
</head>
<body>
  <div class="error-page">
    <div>
      <div class="error-code">500</div>
      <div class="error-title">Internal Server Error</div>
      <p class="text-muted mb-20">Something went wrong on our end. Please try again later.</p>
      <a href="/" class="btn btn-primary">Return Home</a>
    </div>
  </div>
</body>
</html>