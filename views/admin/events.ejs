<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar-admin') %>
  <div class="mobile-overlay" id="mobileOverlay"></div>
  <div class="main-content">
    <div class="topbar">
      <div style="display: flex; align-items: center; gap: 16px;">
        <button class="menu-toggle" id="menuToggle"><i class="fa-solid fa-bars"></i></button>
        <div class="page-title">Manage Events</div>
      </div>
    </div>
    <div class="page-content">
      <% if (error && error.length) { %><div class="alert alert-error"><i class="fa-solid fa-circle-exclamation"></i> <%= error[0] %></div><% } %>
      <% if (success && success.length) { %><div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> <%= success[0] %></div><% } %>

      <div class="grid-2">
        <div class="card">
          <div class="card-header"><div class="card-title">Create New Event</div></div>
          <div class="card-body">
            <form action="/admin/events" method="POST">
              <div class="form-group">
                <label class="form-label">Event Title</label>
                <input type="text" name="title" class="form-control" required>
              </div>
              <div class="form-group">
                <label class="form-label">Description</label>
                <textarea name="description" class="form-control" required></textarea>
              </div>
              <div class="grid-2">
                <div class="form-group">
                  <label class="form-label">Date</label>
                  <input type="date" name="event_date" class="form-control" required>
                </div>
                <div class="form-group">
                  <label class="form-label">Max Volunteers</label>
                  <input type="number" name="max_volunteers" class="form-control" value="10">
                </div>
              </div>
              <div class="form-group">
                <label class="form-label">Location</label>
                <input type="text" name="location" class="form-control" required>
              </div>
              <div class="form-group">
                <label class="form-label">Required Skills (Comma separated)</label>
                <input type="text" name="required_skills" class="form-control" placeholder="e.g. Medical, Driving">
              </div>
              <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">Create Event</button>
            </form>
          </div>
        </div>

        <div style="display: flex; flex-direction: column; gap: 16px;">
          <% if(events && events.length) { %>
            <% events.forEach(e => { %>
              <div class="card">
                <div class="card-body">
                  <div style="display: flex; justify-content: space-between; align-items: start;">
                    <div>
                      <h3 style="font-size: 16px; margin-bottom: 4px; color: var(--slate-900);"><%= e.title %></h3>
                      <div class="text-muted mb-8"><i class="fa-regular fa-calendar"></i> <%= new Date(e.event_date).toDateString() %> | <i class="fa-solid fa-location-dot"></i> <%= e.location %></div>
                      <p style="font-size: 13px; color: var(--slate-700); margin-bottom: 12px;"><%= e.description %></p>
                      <div class="badge badge-pending">
                        <%= e.joined_count %> / <%= e.max_volunteers %> Volunteers Joined
                      </div>
                    </div>
                    <form action="/admin/events/<%= e.id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this event?');">
                      <button type="submit" class="btn btn-danger btn-sm"><i class="fa-solid fa-trash"></i></button>
                    </form>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="empty-state card">
              <div class="empty-icon"><i class="fa-regular fa-calendar-plus"></i></div>
              <h3>No Events Yet</h3>
              <p>Create an event using the form to get started.</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
  document.getElementById('menuToggle').addEventListener('click', () => {
    document.querySelector('.sidebar').classList.add('open');
    document.getElementById('mobileOverlay').classList.add('active');
  });
  document.getElementById('mobileOverlay').addEventListener('click', () => {
    document.querySelector('.sidebar').classList.remove('open');
    document.getElementById('mobileOverlay').classList.remove('active');
  });
</script>
</body>
</html>